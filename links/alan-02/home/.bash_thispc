
alias shtn="echo not yo pc baby!;exit"
alias ll="ls -lah"
alias ta0="tmux attach -t 0"
alias run-forest-run="nodemon -e php -w ./app/Console/Commands -x time php artisan constituent-profile:update --chunk-size 200"
alias format-this-php-codebase="./tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.php"

export EDITOR=nvim

echo 'eval "$(~/.local/bin/mise activate bash)"' >> ~/.bashrc

export PATH=$PATH:/usr/games
export PATH=$PATH:~/.local/bin/
export PATH="$PATH:/opt/nvim-linux64/bin"

export PATH="$(npm config get prefix)/bin:$PATH"
eval "$(zoxide init bash)"
eval "$(starship init bash)"

shuf -n 1 $HOME/static/kanye_quotes.txt | lolcat
echo "        - Kanye West" | lolcat

